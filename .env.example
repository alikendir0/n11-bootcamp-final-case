# Postgres superuser (only used by infra/postgres/init.sh during bootstrap)
POSTGRES_SUPERUSER_PASSWORD=changeme-superuser

# Per-service DB passwords (D-02 — distinct user per schema, role-level cross-schema deny)
# NOTE: schema name is `orders` (not `order`) per RESEARCH finding #5 — `order` is a SQL reserved word
IDENTITY_DB_PASSWORD=changeme-identity
PRODUCT_DB_PASSWORD=changeme-product
INVENTORY_DB_PASSWORD=changeme-inventory
CART_DB_PASSWORD=changeme-cart
ORDERS_DB_PASSWORD=changeme-orders
PAYMENT_DB_PASSWORD=changeme-payment
NOTIFICATION_DB_PASSWORD=changeme-notification
SEARCH_DB_PASSWORD=changeme-search
AI_DB_PASSWORD=changeme-ai
MCP_DB_PASSWORD=changeme-mcp

# RabbitMQ (default-creds-disabled per RESEARCH §14)
RABBITMQ_DEFAULT_USER=n11
RABBITMQ_DEFAULT_PASS=changeme-rabbit

# Phase 3+ (placeholder slots — populated when each owning service lands)

# ── Phase 3 (Identity service) ──────────────────────────────────────
# JWT keypair (D-02) -- RS256 private key in PEM PKCS#8 format.
# Generate with: openssl genrsa 2048 | tee private.pem (then paste contents below
# with literal \n line separators OR use docker-compose env_file multi-line shape).
# NEVER commit private.pem; .gitignore covers *.pem.
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
# JWT_KEY_ID=n11-jwt-2026-04
JWT_PRIVATE_KEY=
JWT_KEY_ID=n11-jwt-2026-04

# Admin seed (D-06) -- one-time bootstrap user inserted by Flyway V2 migration.
# Generate hash with: htpasswd -bnBC 10 "" "your-admin-password" | tr -d ':\n'
# ADMIN_SEED_PASSWORD_HASH must be the bcrypt $2a$10$... shape.
ADMIN_SEED_EMAIL=admin@n11-demo.local
ADMIN_SEED_PASSWORD_HASH=

# ── Phase 6 (payment-service / Iyzico Checkout Form) ──────────────────
# Iyzico sandbox credentials — from https://sandbox.iyzipay.com merchant dashboard.
# NEVER commit real keys. Use sandbox (sandbox-api.iyzipay.com) for Phase 6.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=

# Public HTTPS base URL of the API gateway exposed via Cloudflare Tunnel or ngrok.
# The payment-service appends /api/v1/payments/iyzico/callback to derive the
# Iyzico callbackUrl.  Trailing slash is stripped automatically.
# Example (Cloudflare):  PUBLIC_BASE_URL=https://n11-demo.example.com
# Example (ngrok):        PUBLIC_BASE_URL=https://abc123.ngrok-free.app
PUBLIC_BASE_URL=

# Optional timeout overrides (defaults in payment-service.yml)
# PAYMENT_TIMEOUT_MINUTES=15
# PAYMENT_TIMEOUT_SCAN_DELAY_MS=60000
# IYZICO_DEMO_BUYER_IDENTITY_NUMBER=74300864791

# ── Phase 8 (ai-service) ───────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Phase 9: MCP Server ──────────────────────────────────────────────
# Demo agent API key. Generated at first identity-service boot
# (AgentSeedRunner — Plan 09-02 Task 5) and logged ONCE at WARN level.
# Copy from `docker compose logs identity-service | grep "MCP_API_KEY="`
# into your local .env. The plaintext is NEVER stored anywhere except
# .env (gitignored). On every demo cycle, regenerate by truncating the
# agent_api_keys table in identity-service and restarting (the runner
# re-seeds + re-logs).
MCP_API_KEY=

# ── Phase 11 (Deploy / Demo) ───────────────────────────────────────────
IMAGE_REGISTRY=n11
IMAGE_TAG=dev
# Frontend: leave VITE_API_BASE_URL empty so the SPA uses same-origin /api requests that
# Vite proxies to the gateway (VITE_PROXY_TARGET) — works on localhost and via the tunnel.
VITE_API_BASE_URL=
VITE_PROXY_TARGET=http://api-gateway:8080
CLOUDFLARE_TUNNEL_TOKEN=
NGROK_AUTHTOKEN=
DEMO_TUNNEL_HOSTNAME=

# ── Notifications ──────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
