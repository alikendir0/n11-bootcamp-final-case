# infra-tests/src/test/resources/.env.test
#
# Test-only placeholder passwords for the CrossSchemaDenyTest Testcontainers fixture.
# Deliberately distinct from .env.example (which uses `changeme-*`) so that
# accidental cross-pollination between dev .env and the test container is
# immediately obvious (T-01-14 mitigation).
#
# This file IS in source control because every value below is a placeholder.
# It is NOT loaded by docker-compose, only by tests in this module that pass
# values directly to PostgreSQLContainer.withEnv(...) — see CrossSchemaDenyTest.java.

POSTGRES_PASSWORD=postgres-test

IDENTITY_DB_PASSWORD=i-test
PRODUCT_DB_PASSWORD=p-test
INVENTORY_DB_PASSWORD=iv-test
CART_DB_PASSWORD=c-test
ORDERS_DB_PASSWORD=o-test
PAYMENT_DB_PASSWORD=pa-test
NOTIFICATION_DB_PASSWORD=n-test
SEARCH_DB_PASSWORD=s-test
AI_DB_PASSWORD=ai-test
MCP_DB_PASSWORD=mcp-test
