{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n11clone/saga/envelope.schema.json",
  "title": "Saga Event Envelope",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "occurredAt", "correlationId", "producer", "payload"],
  "additionalProperties": false,
  "properties": {
    "eventId":       { "type": "string", "format": "uuid" },
    "eventType":     { "type": "string", "pattern": "^[a-z]+(\\.[a-z_]+)+$" },
    "eventVersion":  { "type": "integer", "minimum": 1 },
    "occurredAt":    { "type": "string", "format": "date-time" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId":   { "type": ["string", "null"], "format": "uuid" },
    "producer":      { "type": "string", "minLength": 1 },
    "payload":       { "type": "object" }
  }
}
