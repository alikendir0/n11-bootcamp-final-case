{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://n11clone/saga/payment-failed.schema.json",
  "title": "payment.failed payload",
  "type": "object",
  "required": ["orderId", "paymentId", "reason"],
  "additionalProperties": false,
  "properties": {
    "orderId":   { "type": "string", "format": "uuid" },
    "paymentId": { "type": "string", "format": "uuid" },
    "reason":    { "type": "string", "enum": ["DECLINED", "TIMEOUT", "FRAUD", "INSUFFICIENT_FUNDS", "UNKNOWN"] },
    "errorCode": { "type": ["string", "null"] }
  }
}
